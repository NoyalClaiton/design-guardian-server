# Figma Personal Access Token - required for library imports
# Generate at figma.com > Avatar > Settings > Security > Personal access tokens
FIGMA_PAT=your-figma-personal-access-token-here

# Figma OAuth app credentials - required for Sign in with Figma
# Register your app at developer.figma.com
FIGMA_CLIENT_ID=your-figma-oauth-client-id
FIGMA_CLIENT_SECRET=your-figma-oauth-client-secret

# OAuth redirect URI - must match exactly what you set in your Figma app
# For Railway: https://your-app-name.up.railway.app/auth/figma/callback
FIGMA_REDIRECT_URI=https://your-domain.com/auth/figma/callback

# JWT signing secret - generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-random-jwt-secret-here

# Token encryption key - must be exactly 64 hex characters (32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=your-64-char-hex-key-here

# Port (Railway sets this automatically - do not set manually on Railway)
# PORT=3001
