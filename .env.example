# =============================================================================
# Design Guardian Server - Environment Configuration
# =============================================================================
# HOW TO USE THIS FILE:
# 1. Copy this file and rename the copy to .env
# 2. Fill in the real values for each variable below
# 3. Never commit your .env file - it is already excluded by .gitignore
# =============================================================================


# -----------------------------------------------------------------------------
# FIGMA PERSONAL ACCESS TOKEN (required)
# -----------------------------------------------------------------------------
# The server uses this token to fetch your Figma library data (components,
# styles, and variables) on behalf of your team.
#
# How to generate:
#   1. Open Figma in your browser (figma.com)
#   2. Click your avatar or profile photo at the top-right
#   3. Click Settings
#   4. Scroll down to the Security section
#   5. Under Personal access tokens, click Generate new token
#   6. Give it a name like "Design Guardian Server"
#   7. Copy the token immediately - it will not be shown again
#
# Note: Use a token from an account that has access to all the Figma libraries
# your team uses. A dedicated service account is recommended for teams.
# -----------------------------------------------------------------------------
FIGMA_PAT=your-figma-personal-access-token-here


# -----------------------------------------------------------------------------
# FIGMA OAUTH APP CREDENTIALS (required for Sign in with Figma)
# -----------------------------------------------------------------------------
# These allow users to authenticate with their own Figma accounts via OAuth.
# You only need to do this once - one app serves all users.
#
# How to create a Figma OAuth app:
#   1. Go to developer.figma.com
#   2. Click Create a new app
#   3. Fill in app name (e.g. "Design Guardian") and description
#   4. Under Redirect URIs, add your callback URL:
#      - Railway:  https://your-app-name.up.railway.app/auth/figma/callback
#      - Render:   https://your-app-name.onrender.com/auth/figma/callback
#      - Local:    http://localhost:3001/auth/figma/callback
#   5. Save the app - you will see your Client ID and Client Secret
#   6. Copy both values into the fields below
#
# Important: The redirect URI here must match exactly what you set in the app.
# -----------------------------------------------------------------------------
FIGMA_CLIENT_ID=your-figma-oauth-client-id
FIGMA_CLIENT_SECRET=your-figma-oauth-client-secret
FIGMA_REDIRECT_URI=https://your-domain.com/auth/figma/callback


# -----------------------------------------------------------------------------
# JWT SECRET (required)
# -----------------------------------------------------------------------------
# Used to sign and verify authentication tokens issued to the plugin after
# a user completes OAuth. Keep this private - anyone with this value can
# forge tokens.
#
# How to generate a secure value:
#   Run this command in your terminal:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Paste the output (a 64-character hex string) as the value below.
# -----------------------------------------------------------------------------
JWT_SECRET=your-random-jwt-secret-here


# -----------------------------------------------------------------------------
# TOKEN ENCRYPTION KEY (required)
# -----------------------------------------------------------------------------
# Used to encrypt Figma OAuth tokens before storing them in the database.
# Must be exactly 64 hexadecimal characters (32 bytes).
#
# How to generate a secure value:
#   Run this command in your terminal:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Paste the output as the value below. Use a different value than JWT_SECRET.
# -----------------------------------------------------------------------------
TOKEN_ENCRYPTION_KEY=your-64-char-hex-key-here


# -----------------------------------------------------------------------------
# PORT (optional)
# -----------------------------------------------------------------------------
# The port the server listens on. Defaults to 3001 if not set.
#
# Do not set this on Railway or Render - they assign the port automatically
# via their own PORT environment variable. Only set it for local development
# if port 3001 is already in use on your machine.
# -----------------------------------------------------------------------------
# PORT=3001
