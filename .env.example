# =============================================================================
# Design Guardian Server - Environment Configuration
# =============================================================================
# HOW TO USE THIS FILE:
# 1. Copy this file and rename the copy to .env
# 2. Fill in only the variables that apply to your deployment mode
# 3. Never commit your .env file - it is already excluded by .gitignore
#
# DEPLOYMENT MODES:
#   Self-hosted  - Your team runs this server on your own machine or network.
#                  The server fetches Figma data using a shared service token.
#   Cloud        - You deploy this server to Railway, Render, or similar.
#                  Each user signs in with their own Figma account via OAuth.
# =============================================================================


# -----------------------------------------------------------------------------
# FIGMA PERSONAL ACCESS TOKEN
# Mode: Self-hosted only
# -----------------------------------------------------------------------------
# The server uses this token to fetch Figma library data (components, styles,
# and variables) on behalf of your whole team. Not needed in cloud mode -
# each user authenticates with their own account via OAuth instead.
#
# How to generate:
#   1. Open Figma in your browser (figma.com)
#   2. Click your avatar at the top-right
#   3. Go to Settings > Security > Personal access tokens
#   4. Click Generate new token, give it a name like "Design Guardian"
#   5. Copy the token immediately - it will not be shown again
#
# Tip: Use a token from an account that has access to all team libraries.
#      A dedicated service account is recommended for larger teams.
# -----------------------------------------------------------------------------
FIGMA_PAT=your-figma-personal-access-token-here


# -----------------------------------------------------------------------------
# FIGMA OAUTH APP CREDENTIALS
# Mode: Cloud only
# -----------------------------------------------------------------------------
# Allows users to sign in with their own Figma accounts. You only need to
# create this app once - it serves all users of your cloud deployment.
#
# How to create a Figma OAuth app:
#   1. Go to developer.figma.com
#   2. Click Create a new app
#   3. Fill in the app name (e.g. "Design Guardian") and description
#   4. Under Redirect URIs, add your callback URL:
#        Railway: https://your-app-name.up.railway.app/auth/figma/callback
#        Render:  https://your-app-name.onrender.com/auth/figma/callback
#        Local:   http://localhost:3001/auth/figma/callback
#   5. Save - you will see your Client ID and Client Secret
#
# Important: The redirect URI below must match exactly what you set in the app.
# -----------------------------------------------------------------------------
FIGMA_CLIENT_ID=your-figma-oauth-client-id
FIGMA_CLIENT_SECRET=your-figma-oauth-client-secret
FIGMA_REDIRECT_URI=https://your-domain.com/auth/figma/callback


# -----------------------------------------------------------------------------
# JWT SECRET
# Mode: Cloud only
# -----------------------------------------------------------------------------
# Signs and verifies session tokens issued to the plugin after a user
# completes OAuth sign-in. Keep this private.
#
# How to generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Paste the output (64-character hex string) as the value below.
# -----------------------------------------------------------------------------
JWT_SECRET=your-random-jwt-secret-here


# -----------------------------------------------------------------------------
# TOKEN ENCRYPTION KEY
# Mode: Cloud only
# -----------------------------------------------------------------------------
# Encrypts Figma OAuth tokens before storing them in the database.
# Must be exactly 64 hexadecimal characters (32 bytes).
# Use a different value than JWT_SECRET.
#
# How to generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -----------------------------------------------------------------------------
TOKEN_ENCRYPTION_KEY=your-64-char-hex-key-here


# -----------------------------------------------------------------------------
# PORT
# Mode: Both (optional)
# -----------------------------------------------------------------------------
# The port the server listens on. Defaults to 3001 if not set.
# Do not set this on Railway or Render - they assign the port automatically.
# Only set it for local self-hosted use if port 3001 is already in use.
# -----------------------------------------------------------------------------
# PORT=3001
