# =============================================================================
# Design Guardian Server - Configuration
# =============================================================================
# HOW TO USE:
# 1. Copy this file and rename the copy to .env
# 2. Replace the placeholder values with your real values
# 3. Never commit your .env file - it is already excluded by .gitignore
#
# Cloud deployments (Railway, Render, Fly.io): do not use this file.
# Set environment variables directly in your hosting platform's dashboard.
# =============================================================================


# ── Required ──────────────────────────────────────────────────────────────────

# Figma Personal Access Token
# The server uses this to fetch your team's Figma library data.
#
# How to generate:
#   1. Open Figma in your browser (figma.com)
#   2. Click your avatar at the top-right
#   3. Go to Settings > Security > Personal access tokens
#   4. Click Generate new token, give it a name like "Design Guardian"
#   5. Copy the token immediately - it will not be shown again
#
# Use a token from an account that has access to all team libraries.
FIGMA_PAT=your-figma-personal-access-token-here


# ── Optional ──────────────────────────────────────────────────────────────────

# Port (defaults to 3001 if not set)
# PORT=3001


# ── Cloud OAuth mode only ─────────────────────────────────────────────────────
# Only required if you are using cloud mode with Figma OAuth sign-in.

# Secret used to sign JWTs issued to plugin clients. Use a long random string.
# JWT_SECRET=

# 64-character hex string for AES-256-GCM encryption of stored OAuth tokens.
# Generate with: openssl rand -hex 32
# TOKEN_ENCRYPTION_KEY=

# Figma OAuth app credentials from the Figma developer portal.
# FIGMA_CLIENT_ID=
# FIGMA_CLIENT_SECRET=
# FIGMA_REDIRECT_URI=http://localhost:3001/auth/figma/callback
